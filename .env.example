# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Supabase browser-safe values
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase server-only values
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# LiveKit browser-safe URL
NEXT_PUBLIC_LIVEKIT_URL=ws://localhost:7880

# LiveKit server-only credentials
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
LIVEKIT_HOST=localhost
LIVEKIT_HTTP_URL=http://localhost:7880

# AI provider
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_REALTIME_MODEL=
OPENAI_TRANSCRIPTION_MODEL=
OPENAI_TRANSLATION_MODEL=

# Worker
WORKER_NAME=translation-worker-local
WORKER_LOG_LEVEL=debug
WORKER_ROOM_PREFIX=linguabridge

# Storage
STORAGE_PROVIDER=supabase
RECORDINGS_BUCKET=recordings
TRANSCRIPT_EXPORTS_BUCKET=transcript-exports

# Retention
DEFAULT_RETENTION_DAYS=30
MAX_RETENTION_DAYS=30
RETENTION_CRON_SECRET=

# Optional email/invites later
RESEND_API_KEY=
EMAIL_FROM=
